<odoo>
    <data>
      <!--list view-->
      <record model="ir.ui.view" id="bi_student_exam_results_list">
        <field name="name">bi_student_exam_results list</field>
        <field name="model">bi_student_exam.student_exam</field>
        <field name="arch" type="xml">
          <tree>
              <field name="name"/>
              <field name="exam_date"/>
              <field name="total_score" readonly="1"/>
              <field name="average_score" readonly="1"/>
              <field name="rank" readonly="1"/>
              <field name="state" widget ="statusbar"/>

          </tree>
        </field>
      </record>

      <!--form view-->
      <record model="ir.ui.view" id="bi_student_exam_results_form">
        <field name="name">bi_student_exam_results form</field>
        <field name="model">bi_student_exam.student_exam</field>
        <field name="arch" type="xml">
          <form>
            <sheet>
              <group>
                <field name="name"/>
                <field name="student_id"/>
                <field name="exam_date" widget ="date"/>
                <field name="state"/>
                <field name="line_ids">
                  <tree editable="bottom">
                    <field name="subject_name"/>
                    <field name="score"/>
                    <field name="note"/>
                  </tree>
                </field>
                <field name="total_score" readonly="1"/>
                <field name="average_score" readonly="1"/>
                <field name="rank" readonly="1"/>
                <field name="attachment_ids" widget="many2many_binary"/>
              </group>
            </sheet>
          </form>
        </field>
      </record>

      <!-- action -->
      <record model="ir.actions.act_window" id="bi_student_exam_results_action">
        <field name="name">Exam Results</field>
        <field name="res_model">bi_student_exam.student_exam</field>
          <field name="help" type="html">
         <p class="o_view_nocontent_smiling_face">
           No exams found. Let's create one!
         </p>
         <p>To get things done, use activities and status on exams.
         </p></field>
        <field name="view_mode">list,form</field>
      </record>

    </data>
</odoo>