<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="bi_student_exam.StudentInfoWidget" owl="1">
        <div>
            <Many2OneField t-props="props"/>
                <div class="alert alert-info mt-2" t-if="state.student">
                    <h5>Thông tin nhanh</h5>
                        <p>
                        <b>Lớp học:</b>
                        <t t-esc="state.student.class_name"/>
                        </p>
                        <p>
                        <b>Số Điện Thoại:</b>
                        <t t-esc="state.student.phone"/>
                        </p>
                        <p>
                        <b>Email của Người giám hộ:</b>
                        <t t-esc="state.student.guardian_email"/>
                        </p>
                    <button class="btn btn-secondary" t-on-click="refreshInfo"> Refresh Info</button>
                    <button class="btn btn-primary" t-on-click="generateAttachment">Generate Result Attachment</button>
                </div>
        </div>
    </t>

    <t t-name="bi_student_exam.CustomColor" owl="1">
        <t t-if="props.value &lt; 6.5">
            <span style="color:red;font-weight:bold;">
                <t t-esc="props.value"/>
            </span>
        </t>
        <t t-elif="props.value &lt; 8">
            <span style="color:orange;font-weight:bold;">
                <t t-esc="props.value"/>
            </span>
        </t>
        <t t-else="">
            <span style="color:green;font-weight:bold;">
                <t t-esc="props.value"/>
            </span>
        </t>
    </t>
</templates>