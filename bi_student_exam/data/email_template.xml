<odoo>
    <data noupdate="1">
        <record id="email_template_send_result" model="mail.template">
            <field name="name">Send Exam Results</field>
            <field name="model_id" ref="bi_student_exam.model_student_exam"/>
            <field name="subject">Exam Results</field>
            <field name="email_to">"{{ object.student_id.guardian_email }}"</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hello,</p>
                    <p>
                        Student <strong><t t-out="object.student_id.name"/></strong>
                        has exam result like this:
                    </p>
                    <p>
                        Subjects and Scores:
                    </p>
                    <ul>
                        <t t-foreach="object.line_ids" t-as="item">
                            <li>
                                <strong><t t-out="item['subject_name']"/></strong>: 
                                <t t-out="item['score']"/>
                            </li>
                        </t>
                    </ul>
                </div>
            </field>
        </record>
    </data>
</odoo>