<odoo>

<!-- TREE -->
<record id="student_tree_view" model="ir.ui.view">
    <field name="name">student.tree</field>
    <field name="model">student.management.student</field>
    <field name="arch" type="xml">
        <tree>
            <header>
                <button name="action_open_report_wizard"
                        type="object"
                        string="In Báo Cáo"
                        class="btn-primary"/>
            </header>

            <field name="student_code" string="Mã số sinh viên"/>
            <field name="name" string="Tên sinh viên"/>
            <field name="birth_date" string="Ngày sinh"/>
            <field name="gender" string="Giới tính"/>
            <field name="class_id" string="Lớp học"/>
            <field name="gpa" string="GPA"/>
        </tree>
    </field>
</record>

<!-- FORM -->
<record id="student_form_view" model="ir.ui.view">
    <field name="name">student.form</field>
    <field name="model">student.management.student</field>
    <field name="arch" type="xml">
        <form>
            <header>
                <button name="action_open_report_wizard"
                        type="object"
                        string="In Báo Cáo"
                        class="btn-primary"/>
            </header>

            <sheet>

                <group>
                    <field name="student_code" string="Mã số sinh viên"/>
                    <field name="name" string="Tên sinh viên"/>
                    <field name="birth_date" widget="date" string="Ngày sinh"/>
                    <field name="gender" string="Giới tính"/>
                    <field name="class_id" string="Lớp học"/>
                    <field name="gpa" widget="gpa_color" readonly="1" string="GPA"/>
                </group>

                <notebook>

                    <page string="Bảng điểm">

                        <field name="score_ids">
                            <tree editable="bottom">
                                <field name="subject" string="Môn học"/>
                                <field name="score" string="Điểm"/>
                                <field name="note" string="Ghi chú"/>
                            </tree>
                        </field>

                    </page>

                    <page string="Đính Kèm">
                        <field name="attachment_ids"/>
                    </page>

                </notebook>

            </sheet>

        </form>
    </field>
</record>

<!-- SEARCH -->
<record id="student_search_view" model="ir.ui.view">
    <field name="name">student.search</field>
    <field name="model">student.management.student</field>
    <field name="arch" type="xml">
        <search>
            <field name="name" string="Tên sinh viên"/>
            <field name="student_code" string="Mã số sinh viên"/>
            <field name="class_id" string="Lớp học"/>
        </search>
    </field>
</record>

<!-- ACTION -->
<record id="student_action" model="ir.actions.act_window">
    <field name="name">Students</field>
    <field name="res_model">student.management.student</field>
    <field name="view_mode">tree,form,kanban</field>
</record>

</odoo>