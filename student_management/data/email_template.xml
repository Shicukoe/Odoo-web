<odoo>

<record id="email_template_gpa_warning"
        model="mail.template">

    <field name="name">Low GPA Warning</field>

    <field name="model_id"
           ref="model_student_management_student"/>

    <field name="subject">
        GPA Warning
    </field>

    <field name="email_to">
        ${object.create_uid.email}
    </field>

    <field name="body_html">

        <![CDATA[

        <p>Hello,</p>

        <p>
        Student <strong>${object.name}</strong>
        has GPA below average.
        </p>

        <p>
        Current GPA: ${object.gpa}
        </p>

        ]]>

    </field>

</record>

</odoo>