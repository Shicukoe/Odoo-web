<odoo>

<record id="email_template_gpa_warning" model="mail.template">
    <field name="name">Low GPA Warning</field>
    <field name="model_id" ref="model_student_management_student"/>
    <field name="subject">GPA Warning</field>
    <field name="email_to">keotran15@gmail.com</field>
    <field name="body_html" type="html">
        <div>
            <p>Hello,</p>
            <p>
            Student <strong> {{ ctx.get('student_name') }} </strong> has GPA below average.
            </p>
            <p>
            Current GPA: {{ ctx.get('student_gpa') }}
            </p>
        </div>
    </field>
</record>

</odoo>