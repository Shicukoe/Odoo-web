<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="student_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="student">
                <t t-call="web.external_layout">

                    <div class="page" style="font-family: 'DejaVu Sans', Arial, sans-serif; font-size:14px;">

                        <h2 class="text-center">Báo cáo kết quả học tập của sinh viên</h2>

                        <br/>

                        <p>
                            <strong>Tên Sinh Viên:</strong>
                            <span t-esc="student.name"/>
                        </p>

                        <p>
                            <strong>Mã Sinh Viên:</strong>
                            <span t-esc="student.student_code"/>
                        </p>

                        <p>
                            <strong>Lớp:</strong>
                            <span t-esc="student.class_id.name"/>
                        </p>

                        <br/>

                        <table style="width:100%; border-collapse:collapse;">
                            <thead>
                                <tr>
                                    <th style="border:1px solid black; padding:8px;">Môn học</th>
                                    <th style="border:1px solid black; padding:8px;">Điểm</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr t-foreach="student.score_ids" t-as="score">
                                    <td style="border:1px solid black; padding:8px;">
                                        <span t-esc="score.subject"/>
                                    </td>
                                    <td style="border:1px solid black; padding:8px;">
                                        <span t-esc="score.score"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <br/>

                        <p>
                            <strong>GPA:</strong>
                            <span t-esc="student.gpa"/>
                        </p>

                    </div>

                </t>
            </t>
        </t>
    </template>

</odoo>