<odoo>

<template id="student_report_template">

<t t-call="web.html_container">

<t t-foreach="docs" t-as="student">

<div class="page">

<h2>Student Report</h2>

<p>
Name:
<t t-esc="student.name"/>
</p>

<p>
Student Code:
<t t-esc="student.student_code"/>
</p>

<p>
Class:
<t t-esc="student.class_id.name"/>
</p>

<table class="table table-bordered">

<thead>
<tr>
<th>Subject</th>
<th>Score</th>
</tr>
</thead>

<tbody>

<tr t-foreach="student.score_ids" t-as="score">

<td>
<t t-esc="score.subject"/>
</td>

<td>
<t t-esc="score.score"/>
</td>

</tr>

</tbody>

</table>

<p>
GPA:
<t t-esc="student.gpa"/>
</p>

</div>

</t>

</t>

</template>

</odoo>