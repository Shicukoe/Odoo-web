<odoo>
  <data>

    <!-- Tree -->
    <record id="view_dw_record_tree" model="ir.ui.view">
      <field name="name">lamgido.dw.record.tree</field>
      <field name="model">lamgido.dw.record</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="date"/>
          <field name="category_id"/>
          <field name="quantity"/>
          <field name="size_per_unit"/>
          <field name="size_unit"/>
          <field name="total_size_kb"/>
          <field name="state"/>

          <button name="action_confirm"
                  type="object"
                  string="Confirm"
                  states="draft"
                  class="oe_highlight"/>

          <button name="action_done"
                  type="object"
                  string="Done"
                  states="confirmed"
                  class="btn-success"/>

          <button name="action_reset_to_draft"
                  type="object"
                  string="Reset"
                  states="done"/>
        </tree>
      </field>
    </record>

    <!-- Form -->
    <record id="view_dw_record_form" model="ir.ui.view">
      <field name="name">lamgido.dw.record.form</field>
      <field name="model">lamgido.dw.record</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_confirm"
                    type="object"
                    string="Confirm"
                    states="draft"
                    class="btn-primary"/>

            <button name="action_done"
                    type="object"
                    string="Mark as Done"
                    states="confirmed"
                    class="btn-success"/>

            <button name="action_reset_to_draft"
                    type="object"
                    string="Reset"
                    states="done"/>

            <field name="state"
                   widget="statusbar"
                   statusbar_visible="draft,confirmed,done"/>
          </header>

          <sheet>
            <div class="oe_button_box" name="button_box">
              <button name="action_open_invoice"
                      type="object"
                      class="oe_stat_button"
                      icon="fa-file-text-o"
                      attrs="{'invisible': [('invoice_id', '=', False)]}">
                <field name="invoice_id" widget="statinfo" string="Invoice"/>
              </button>
            </div>
            <group>
              <field name="name"/>
              <field name="date"/>
              <field name="category_id"/>
            </group>
          
            <notebook>
              <page string="Storage Information">
                  <group>
                      <field name="quantity"/>
                      <field name="size_per_unit"/>
                      <field name="size_unit"/>
                      <field name="total_size_kb" readonly="1"/>
                  </group>
              </page>

              <page string="Owner Information">
                <group>
                  <field name="owner"/>
                  <field name="owner_partner_id"/>
                </group>
              </page>
            </notebook>

          </sheet>

          

        </form>
      </field>
    </record>

    <!-- Action -->
    <record id="action_dw_records" model="ir.actions.act_window">
      <field name="name">DW Records</field>
      <field name="res_model">lamgido.dw.record</field>
      <field name="view_mode">kanban,tree,form,graph,pivot</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_dw_root"
              name="Data Warehouse"
              sequence="10"/>

    <menuitem id="menu_dw_categories"
              name="Categories"
              parent="menu_dw_root"
              action="action_dw_categories"
              sequence="10"/>

    <menuitem id="menu_dw_records"
              name="Records &amp; Reports"
              parent="menu_dw_root"
              action="action_dw_records"
              sequence="20"/>

  </data>
</odoo>