<odoo>
  <data>

    <record id="view_dw_category_tree" model="ir.ui.view">
      <field name="name">lamgido.dw.category.tree</field>
      <field name="model">lamgido.dw.category</field>
      <field name="arch" type="xml">              
        <tree editable="bottom">
          <field name="name"/>
          <field name="description"/>
          <field name="active"/>
        </tree>
      </field>
    </record>

    <record id="view_dw_category_form" model="ir.ui.view">
      <field name="name">lamgido.dw.category.form</field>
      <field name="model">lamgido.dw.category</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <div class="oe_button_box" name="button_box">
              <button type="object"
                      name="action_view_records"
                      class="oe_stat_button"
                      icon="fa-database">
                  <field name="record_count"
                        string="Records"
                        widget="statinfo"/>
              </button>
            </div>
            <group>
              <field name="name"/>
              <field name="active"/>
            </group>
            <group>
              <field name="description"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_dw_categories" model="ir.actions.act_window">
      <field name="name">DW Categories</field>
      <field name="res_model">lamgido.dw.category</field>
      <field name="view_mode">tree,form</field>

    </record>

  </data>
</odoo>