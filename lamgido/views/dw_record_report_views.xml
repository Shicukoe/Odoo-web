<odoo>
  <data>

    <record id="view_dw_record_graph" model="ir.ui.view">
    <field name="name">lamgido.dw.record.graph</field>
    <field name="model">lamgido.dw.record</field>
    <field name="arch" type="xml">
        <graph string="Total Storage by Category" type="bar">
            <field name="category_id" type="row"/>
            <field name="owner" type="row"/>
            <field name="total_size_kb" type="measure"/>
        </graph>
      </field>
    </record>

    <record id="view_dw_record_pivot" model="ir.ui.view">
    <field name="name">lamgido.dw.record.pivot</field>
    <field name="model">lamgido.dw.record</field>
    <field name="arch" type="xml">
        <pivot string="DW Storage Analysis">
            <field name="category_id" type="row"/>
            <field name="owner" type="row"/>
            <field name="date" interval="month" type="col"/>
            <field name="total_size_kb" type="measure"/>
            <field name="quantity" type="measure"/>
        </pivot>
      </field>
    </record>

  <record id="view_dw_record_kanban" model="ir.ui.view">
      <field name="name">lamgido.dw.record.kanban</field>
      <field name="model">lamgido.dw.record</field>
      <field name="arch" type="xml">
          <kanban default_group_by="state">
              <field name="name"/>
              <field name="total_size_kb"/>
              <field name="owner"/>
              <field name="state"/>

              <templates>
                  <t t-name="kanban-box">
                      <div class="oe_kanban_card">
                          <div class="oe_kanban_content">
                              <strong>
                                  <field name="name"/>
                              </strong>
                              <div>
                                  Owner: <field name="owner"/>
                              </div>
                              <div>
                                  Size: <field name="total_size_kb"/> KB
                              </div>
                              <div>
                                  State: <field name="state"/>
                              </div>
                          </div>
                      </div>
                  </t>
              </templates>
          </kanban>
      </field>
  </record>

  </data>
</odoo>
